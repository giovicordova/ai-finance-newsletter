# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — never commit it.

# From @BotFather on Telegram. Format: 123456:ABC-your-token-here
TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather

# Channel/group chat ID. Negative integer for channels, e.g. -1001234567890.
# See docs/TELEGRAM.md for how to obtain it.
TELEGRAM_CHAT_ID=your-channel-id-here
